/* 错题伙伴 · 原型全局样式（与 prototype/index.html 视觉对齐） */
page { background: #f6f7fb; font-size: 30rpx; color: #2d2f3a; }

.wrap { padding: 28rpx; padding-bottom: 160rpx; }

/* 顶栏 */
.topbar { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.back { background: #fff; border-radius: 18rpx; width: 64rpx; height: 64rpx; line-height: 64rpx;
        text-align: center; font-size: 34rpx; flex: none; }
.h1 { font-size: 34rpx; font-weight: 700; flex: 1; }
.dots { display: flex; gap: 10rpx; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #d6d9e6; }
.dot-on { background: #6c5ce7; }

.card { background: #fff; border-radius: 28rpx; padding: 28rpx; margin-bottom: 22rpx;
        box-shadow: 0 2rpx 8rpx rgba(80,80,120,.06); }
.title { font-size: 31rpx; font-weight: 700; }
.muted { color: #8a8fa3; font-size: 25rpx; line-height: 1.6; }
.tag { display: inline-block; background: #efedfd; color: #6c5ce7; font-size: 23rpx;
       border-radius: 14rpx; padding: 4rpx 16rpx; margin-right: 10rpx; }

.btn { background: #6c5ce7; color: #fff; border-radius: 24rpx; padding: 26rpx;
       font-size: 31rpx; font-weight: 600; text-align: center; margin-top: 20rpx; }
.btn-ghost { background: #fff; color: #6c5ce7; border: 2.5rpx solid #d8d3f8; font-weight: 500; }
.btn-big { padding: 34rpx; font-size: 33rpx; border-radius: 32rpx; }
.btn-sm { font-size: 25rpx; padding: 14rpx; margin-top: 14rpx; }

/* 对话 */
.chat { display: flex; flex-direction: column; gap: 18rpx; }
.row { display: flex; gap: 14rpx; align-items: flex-end; }
.row-me { flex-direction: row-reverse; }
.avatar { width: 62rpx; height: 62rpx; border-radius: 50%; background: #fff; text-align: center;
          line-height: 62rpx; font-size: 36rpx; flex: none; box-shadow: 0 2rpx 6rpx rgba(0,0,0,.08); }
.bubble { max-width: 78%; padding: 20rpx 24rpx; border-radius: 28rpx; font-size: 29rpx; line-height: 1.55;
          background: #fff; border-bottom-left-radius: 8rpx; box-shadow: 0 2rpx 6rpx rgba(80,80,120,.06); }
.bubble-me { background: #6c5ce7; color: #fff; border-bottom-left-radius: 28rpx; border-bottom-right-radius: 8rpx; }

/* 录音按钮三态 */
.mic { display: flex; align-items: center; justify-content: center; border-radius: 24rpx;
       padding: 26rpx; font-size: 29rpx; font-weight: 600; background: #ffe9e3; color: #e0552f;
       margin-top: 20rpx; }
.mic-rec { background: #e0552f; color: #fff; animation: pulse 1s infinite; }
.mic-busy { background: #f0f0f6; color: #8a8fa3; }
@keyframes pulse { 50% { opacity: .75; } }

/* 题目框 */
.qbox { background: #fffdf3; border: 2.5rpx dashed #e8c66a; border-radius: 20rpx; padding: 26rpx;
        font-size: 33rpx; text-align: center; line-height: 1.7; margin-top: 16rpx; }
.frac { display: inline-block; text-align: center; vertical-align: middle; margin: 0 6rpx; }
.fn { display: block; padding: 0 10rpx; font-size: 29rpx; border-bottom: 3rpx solid #333; }
.fd { display: block; padding: 0 10rpx; font-size: 29rpx; }

/* 选项 */
.opts { display: flex; flex-wrap: wrap; gap: 18rpx; margin-top: 22rpx; }
.opt { width: calc(50% - 9rpx); box-sizing: border-box; border: 2.5rpx solid #e3e5f0; background: #fff;
       border-radius: 20rpx; padding: 26rpx; font-size: 33rpx; text-align: center; }
.opt-right { border-color: #27ae60; background: #eafaf0; }
.opt-wrong { border-color: #e0552f; background: #fdf0ec; }

/* 怪兽与能量条 */
.monster { display: flex; align-items: center; gap: 18rpx; padding: 18rpx 0; }
.m-emoji { font-size: 56rpx; }
.m-body { flex: 1; }
.m-name { font-size: 27rpx; font-weight: 600; }
.m-val { color: #8a8fa3; font-size: 27rpx; }
.m-up { color: #27ae60; font-weight: 700; font-size: 27rpx; }
.energy { height: 18rpx; background: #edeef5; border-radius: 10rpx; overflow: hidden; margin-top: 10rpx; }
.energy-i { display: block; height: 100%; background: linear-gradient(90deg, #a29bfe, #6c5ce7);
            border-radius: 10rpx; }

/* 提示条 */
.note { background: #fff8e8; border-radius: 18rpx; padding: 18rpx 22rpx; font-size: 24rpx;
        color: #9a7b2d; line-height: 1.6; margin-top: 18rpx; }
.note-good { background: #eafaf0; color: #1e7e46; }
.placeholder { font-size: 21rpx; color: #b6b9c8; text-align: center; margin-top: 10rpx; }

/* 归因 chips */
.cause { display: flex; gap: 14rpx; flex-wrap: wrap; margin-top: 18rpx; }
.chip { border: 2.5rpx solid #e3e5f0; background: #fff; border-radius: 36rpx; padding: 12rpx 26rpx;
        font-size: 27rpx; }
.chip-on { border-color: #6c5ce7; background: #efedfd; color: #6c5ce7; font-weight: 600; }

/* 拍照 */
.photo-prev { width: 100%; border-radius: 16rpx; border: 4rpx dashed #6c5ce7; margin-top: 16rpx; }
.ocr-edit { width: 100%; box-sizing: border-box; border: 2.5rpx solid #d8d3f8; border-radius: 20rpx;
            padding: 22rpx; font-size: 31rpx; line-height: 1.6; background: #fcfbff; margin-top: 14rpx;
            min-height: 120rpx; }

/* 打卡进度 */
.progress2 { display: flex; gap: 18rpx; margin-top: 20rpx; }
.pstep { flex: 1; background: #f6f7fb; border-radius: 20rpx; padding: 22rpx; font-size: 25rpx; line-height: 1.6; }
.st { font-size: 34rpx; }

/* 打卡成功 */
.celebrate { text-align: center; padding-top: 70rpx; }
.big-emoji { font-size: 130rpx; }
.celebrate-h { font-size: 40rpx; font-weight: 800; margin-top: 16rpx; }
.ticket { background: linear-gradient(135deg, #ffb347, #ff8008); color: #fff; border-radius: 28rpx;
          padding: 32rpx; margin: 30rpx 0; text-align: center; line-height: 1.8; }
.ticket-b { font-size: 38rpx; font-weight: 800; }
